@{
    ViewData["Title"] = "Iscrizione Completata";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="mb-4">
                <i class="fas fa-check-circle fa-7x" style="color: #4CAF50;"></i>
            </div>

            <h1 class="display-4 fw-bold mb-3">Iscrizione Inviata!</h1>
            <p class="lead mb-5">
                Grazie per aver registrato la squadra <strong>@ViewBag.TeamName</strong>.<br />
                I dati e i documenti sono stati caricati correttamente nei nostri sistemi.
            </p>
        </div>
    </div>
</div>